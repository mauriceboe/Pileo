# -- Server --
PILEO_PORT=3000
PILEO_HOST=0.0.0.0
PILEO_BASE_URL=http://localhost:3000
PILEO_LOG_LEVEL=info                    # debug | info | warn | error

# -- Database --
PILEO_DB_PATH=./data/pileo.db

# -- Session --
PILEO_SESSION_SECRET=generate-a-64-char-random-string
PILEO_SESSION_MAX_AGE=604800000         # 7 days in milliseconds

# -- File Storage --
PILEO_UPLOAD_DIR=./data/uploads
PILEO_MAX_FILE_SIZE=10485760            # 10 MB in bytes

# -- Email (optional) --
PILEO_SMTP_HOST=
PILEO_SMTP_PORT=587
PILEO_SMTP_USER=
PILEO_SMTP_PASSWORD=
PILEO_SMTP_FROM=noreply@pileo.local

# -- Security --
PILEO_CORS_ORIGIN=http://localhost:5173
PILEO_RATE_LIMIT_WINDOW=60000           # 1 minute
PILEO_RATE_LIMIT_MAX=100

# -- Registration --
PILEO_REGISTRATION_ENABLED=true         # Set false to disable public registration
PILEO_INVITE_ONLY=false                 # Require invite link to register
